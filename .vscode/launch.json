{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SynCo Site: F5 デバッグ",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vinext/dist/cli.js",
      "args": [
        "dev",
        "--host",
        "127.0.0.1",
        "--port",
        "3000"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "debugWithChrome",
        "webRoot": "${workspaceFolder}"
      }
    }
  ]
}
